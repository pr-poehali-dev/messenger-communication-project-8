{
  "tests": [
    {
      "name": "Login with correct password (GET)",
      "method": "GET",
      "path": "/?action=login&username=%D0%A2%D0%B5%D1%81%D1%82%D0%A0%D0%B5%D0%B377&password=test1234",
      "expectedStatus": 200,
      "expectedBody": { "session_id": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "GET",
      "path": "/?action=login&username=%D0%A2%D0%B5%D1%81%D1%82%D0%A0%D0%B5%D0%B377&password=wrong",
      "expectedStatus": 401
    },
    {
      "name": "Join by unknown session (GET)",
      "method": "GET",
      "path": "/?action=join&sid=auth_nonexistent000000000000000000000",
      "expectedStatus": 401
    },
    {
      "name": "Get messages",
      "method": "GET",
      "path": "/?action=messages",
      "expectedStatus": 200
    },
    {
      "name": "Get online count",
      "method": "GET",
      "path": "/?action=online",
      "expectedStatus": 200
    },
    {
      "name": "Poll endpoint (no session)",
      "method": "GET",
      "path": "/?action=poll",
      "expectedStatus": 200,
      "expectedBody": { "dm_unread": 0 },
      "bodyMatcher": "partial"
    },
    {
      "name": "Longpoll endpoint (no session, returns immediately)",
      "method": "GET",
      "path": "/?action=longpoll",
      "expectedStatus": 200,
      "expectedBody": { "dm_unread": 0 },
      "bodyMatcher": "partial"
    }
  ]
}